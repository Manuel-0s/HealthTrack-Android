<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historial de métricas"
            android:textColor="@color/text_primary" android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Últimos 7 días de registros"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <HorizontalScrollView
            android:id="@+id/chipsScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupMetrics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGlucose"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Glucosa"
                    android:checked="true"
                    app:chipBackgroundColor="@color/primary_green"
                    android:textColor="@color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHeartRate"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Frecuencia" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIMC"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMC" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPressure"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Presión" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <GridLayout
            android:id="@+id/statsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:rowCount="2"
            app:layout_constraintTop_toBottomOf="@id/chipsScroll">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/white" app:strokeWidth="0dp" app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Promedio"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvAvgValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- mg/dL"
                        android:textColor="@color/text_primary" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvAvgStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:textColor="@color/primary_green"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/white" app:strokeWidth="0dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Último registro"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvLastValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- mg/dL"
                        android:textColor="@color/text_primary" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvLastStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elevado"
                        android:textColor="@color/status_elevated"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/white" app:strokeWidth="0dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mínimo"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvMinValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- mg/dL"
                        android:textColor="@color/text_primary" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvMinStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Óptimo"
                        android:textColor="@color/primary_green"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/white" app:strokeWidth="0dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Máximo"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvMaxValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- mg/dL"
                        android:textColor="@color/text_primary" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvMaxStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alto"
                        android:textColor="@color/status_high"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chartCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white" app:strokeWidth="0dp"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/statsGrid">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tendencia semanal"
                    android:textColor="@color/text_primary" android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvChartSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Glucosa en mg/dL — últimos 7 días"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/chartCard"
            tools:listitem="@layout/item_history_record" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>