<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAppointmentIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="@color/primary_green_light"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivAppointmentIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/primary_green"
                tools:ignore="ContentDescription" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvAppointmentReason"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/cardAppointmentStatus"
            app:layout_constraintStart_toEndOf="@id/cardAppointmentIcon"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Dolor lumbar persistente" />

        <TextView
            android:id="@+id/tvAppointmentDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="@id/tvAppointmentReason"
            app:layout_constraintStart_toStartOf="@id/tvAppointmentReason"
            app:layout_constraintTop_toBottomOf="@id/tvAppointmentReason"
            tools:text="22/05/2026 18:24" />

        <TextView
            android:id="@+id/tvAppointmentNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#F8F9FA"
            android:padding="10dp"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/cardAppointmentIcon"
            app:layout_constraintTop_toBottomOf="@id/tvAppointmentDateTime"
            tools:text="Notas: Paciente estable. Continuar con tratamiento indicado." />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAppointmentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#33FF5252"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvAppointmentStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="#FF5252"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Cancelada" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>