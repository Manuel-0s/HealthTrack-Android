<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIconContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="@color/primary_green_light"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivTreatmentIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_medication"
                app:tint="@color/primary_green" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvMedicineName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardIconContainer"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Metformina" />

        <TextView
            android:id="@+id/tvMedicineDose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="@id/tvMedicineName"
            app:layout_constraintTop_toBottomOf="@id/tvMedicineName"
            tools:text="850 mg" />

        <TextView
            android:id="@+id/tvMedicineFrequency"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintBaseline_toBaselineOf="@id/tvMedicineDose"
            app:layout_constraintEnd_toStartOf="@id/tvMedicineDose"
            app:layout_constraintStart_toStartOf="@id/tvMedicineName"
            tools:text="Cada 12 horas" />

        <TextView
            android:id="@+id/tvMedicineDuration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/tvMedicineDose"
            app:layout_constraintStart_toStartOf="@id/tvMedicineName"
            app:layout_constraintTop_toBottomOf="@id/tvMedicineDose"
            tools:text="Durante 3 meses" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>