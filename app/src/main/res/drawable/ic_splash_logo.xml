<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo circular con gradiente -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="45"
                android:startColor="#0B9A7B"
                android:endColor="#26C6A2"
                android:type="linear" />
            <size android:width="108dp" android:height="108dp" />
        </shape>
    </item>

    <!-- Borde blanco translúcido -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <stroke android:width="1.5dp" android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- Ícono centrado -->
    <item
        android:top="22dp"
        android:bottom="22dp"
        android:left="22dp"
        android:right="22dp">
        <vector
            android:width="64dp"
            android:height="64dp"
            android:viewportWidth="24"
            android:viewportHeight="24">

            <!-- Corazón -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M12,20.5l-1.3-1.2C5.6,14.8 2,11.9 2,8.5C2,5.4 4.4,3 7.5,3C9.2,3 10.9,3.8 12,5.1C13.1,3.8 14.8,3 16.5,3C19.6,3 22,5.4 22,8.5C22,11.9 18.4,14.8 13.3,19.3L12,20.5Z"/>

            <!-- Línea de pulso -->
            <path
                android:strokeColor="#0B9A7B"
                android:strokeWidth="1.8"
                android:strokeLineCap="round"
                android:strokeLineJoin="round"
                android:fillColor="@android:color/transparent"
                android:pathData="M6,12h2.5l1,-3l2,6l1,-3h3"/>

        </vector>
    </item>

</layer-list>